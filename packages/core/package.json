{
  "name": "@chonkiejs/core",
  "version": "0.0.9",
  "description": "Core chunking library for Chonkie - lightweight and efficient text chunking",
  "license": "MIT",
  "homepage": "https://docs.chonkie.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chonkie-inc/chonkiejs.git",
    "directory": "packages/core"
  },
  "author": "Bhavnick Minhas",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

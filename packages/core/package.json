  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tree-sitter-wasms": "^0.1.13",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"

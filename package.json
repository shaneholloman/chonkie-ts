{
  "name": "chonkie-main",
  "version": "0.3.0",
  "private": true,
  "description": "Monorepo for Chonkie - lightweight and efficient text chunking library",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chonkie-inc/chonkiejs.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rimraf --glob packages/*/dist",
    "build": "npm run clean && npm run build --workspace=packages/core",
    "test": "npm run build && npm run test --workspace=packages/core",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^22.15.21",
    "publint": "^0.3.14",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}